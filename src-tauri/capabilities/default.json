{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:tray:default",
    "core:menu:default",
    "dialog:default",
    "shell:allow-open",
    "clipboard-manager:default",
    "fs:default"
  ]
}
